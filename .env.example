# OpenRouter API Key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Default model for AI tasks (can be changed in the UI)
# Free models: google/gemma-2-9b-it:free, mistralai/mistral-7b-instruct:free
# Paid models: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet
DEFAULT_MODEL=google/gemma-2-9b-it:free

# Server port
PORT=3001

# Database path (relative to server/)
DATABASE_PATH=./data/lectronic-recall.db
